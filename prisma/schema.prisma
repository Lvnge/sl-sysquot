datasource db {
  provider = "postgresql"
}
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}
model SenderProfile {
  id        Int     @id @default(autoincrement())
  name      String  @default("")
  company   String  @default("")
  phone     String  @default("")
  email     String  @default("")
  address   String  @default("")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  company   String?
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  quotes    Quote[]
}

model Quote {
  id        Int         @id @default(autoincrement())
  folio     String      @unique
  clientId  Int
  client    Client      @relation(fields: [clientId], references: [id])
  maqBrand  String?
  maqModel  String?
  maqType   String?
  maqSerial String?
  maqHours  String?
  maqCondition String?
  delivery  String?
  validity  String?
  notes     String?
  advance   Float?
  status    String      @default("Borrador")
  items     QuoteItem[]
  createdAt DateTime    @default(now())
}

model QuoteItem {
  id      Int    @id @default(autoincrement())
  quoteId Int
  quote   Quote  @relation(fields: [quoteId], references: [id])
  section String
  desc    String
  qty     Float
  price   Float
}

model CatalogItem {
  id    Int     @id @default(autoincrement())
  name  String
  type  String
  price Float
  desc  String?
}